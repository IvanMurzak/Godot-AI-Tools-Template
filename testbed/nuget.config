<?xml version="1.0" encoding="utf-8"?>
<!--
  Adds the repo-local `local-nuget/` folder as a package source so the testbed can restore the extension
  package BEFORE it is published to nuget.org. CI fills it with `dotnet pack -o local-nuget
  -p:Version=0.0.0-ci`. The path is relative to this file (testbed/), so `../local-nuget` = repo root.
  nuget.org stays enabled for GodotSharp + the MCP/reflection pins.
-->
<configuration>
  <packageSources>
    <add key="local-nuget" value="../local-nuget" />
  </packageSources>
</configuration>
