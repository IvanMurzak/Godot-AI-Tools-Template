<?xml version="1.0" encoding="utf-8"?>
<!--
  ┌──────────────────────────────────────────────────────────────────────────────────────────────┐
  │  SOURCE INJECTION — the consumer half of the source-only package recipe.                       │
  └──────────────────────────────────────────────────────────────────────────────────────────────┘

  NuGet auto-imports `build/<PackageId>.props` into any project that references this package. This file
  MUST be named exactly `<PackageId>.props` (com.IvanMurzak.Godot.MCP.YOUR_FEATURE.props) or NuGet will
  not import it. `bump-version` / `init` keep the name in lockstep with <PackageId>.

  It adds this package's packed `.cs` (which sit in the NuGet cache under `<package>/<version>/src/`) as
  <Compile> items in the CONSUMER's project, so they compile INSIDE the consumer's Godot project against
  the consumer's own GodotSharp. Because the consumer is a `Godot.NET.Sdk` project, `Godot` types resolve
  and `#if TOOLS` is defined for the editor build — exactly as if the source lived in the consumer's repo.

  • $(MSBuildThisFileDirectory) resolves to `<package>/<version>/build/` in the NuGet cache, so
    `../src/**/*.cs` is the packed source.
  • Exclude="@(Compile)" is belt-and-suspenders against double-inclusion (the consumer's own default
    glob never reaches the NuGet cache, so it normally excludes nothing).
  • Link groups the injected files under the package id in IDEs (cosmetic).
-->
<Project>
  <ItemGroup>
    <Compile Include="$(MSBuildThisFileDirectory)..\src\**\*.cs"
             Exclude="@(Compile)"
             Link="com.IvanMurzak.Godot.MCP.YOUR_FEATURE\%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>
</Project>
